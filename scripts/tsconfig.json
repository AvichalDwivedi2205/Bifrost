{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "types": ["bun-types"],
    "baseUrl": "..",
    "paths": {
      "@bifrost/shared": ["packages/shared/src/index.ts"]
    }
  },
  "include": ["./*.ts"]
}
